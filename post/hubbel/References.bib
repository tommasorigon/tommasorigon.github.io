@article{Favaro2015,
	abstract = {We investigate the use of a large class of discrete random probability measures, which is referred to as the class (Formula presented.), in the context of Bayesian nonparametric mixture modeling. The class (Formula presented.) encompasses both the the two-parameter Poisson--Dirichlet process and the normalized generalized Gamma process, thus allowing us to comparatively study the inferential advantages of these two well-known nonparametric priors. Apart from a highly flexible parameterization, the distinguishing feature of the class (Formula presented.) is the availability of a tractable posterior distribution. This feature, in turn, leads to derive an efficient marginal MCMC algorithm for posterior sampling within the framework of mixture models. We demonstrate the efficacy of our modeling framework on both one-dimensional and multi-dimensional datasets.},
	author = {Favaro, S. and Lomeli, M. and Teh, Y. W.},
	date-added = {2023-12-13 11:32:26 +0100},
	date-modified = {2024-04-22 15:59:18 +0200},
	journal = {Statist. Comp.},
	number = {1},
	pages = {67--78},
	title = {{On a class of sigma-stable Poisson--Kingman models and an effective marginalized sampler}},
	volume = {25},
	year = {2015},
	bdsk-url-1 = {https://doi.org/10.1007/s11222-014-9499-4}}

